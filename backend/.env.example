# Copia este archivo a .env y reemplaza los valores de ejemplo con los tuyos.
# Nunca subas el .env real: contiene credenciales.

# --- Base de datos (requerido) ---
# Conexion a PostgreSQL (Supabase, Session pooler).
# Si la contrasena tiene simbolos (& @ : / etc.) hay que URL-encodearlos.
#
# Lo que copia Supabase usa el driver SINCRONO psycopg2 y NO funciona aqui:
# la app es async. Usa el esquema de abajo, que solo agrega +asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase (requerido) ---
# URL del proyecto (Project Settings -> API -> Project URL).
# De aqui se derivan el JWKS endpoint y el issuer para verificar los tokens ES256.
SUPABASE_URL=https://<project-ref>.supabase.co

# --- Telegram (opcional) ---
# Alertas a familiares cuando una toma queda vencida. Sin token, se desactivan.
# Crea el bot con @BotFather; usa el token que entrega y el username sin la @.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Proveedor de IA
# Usa Gemini 1.5 Flash desde Google AI Studio si prefieres este modelo.
GEMINI_API_KEY=

# --- IA (opcional) ---
# Key de GLM/Zhipu para el analisis de sintomas. Sin ella se usa el stub local.
ZHIPU_API_KEY=